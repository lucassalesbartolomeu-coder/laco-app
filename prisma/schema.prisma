generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth Models ───────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("COUPLE") // COUPLE, PLANNER, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  weddings       Wedding[]
  weddingPlanner WeddingPlanner?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Wedding Models ────────────────────────────────────────

model Wedding {
  id              String    @id @default(cuid())
  userId          String
  slug            String?   @unique
  partnerName1    String
  partnerName2    String
  weddingDate     DateTime?
  venue           String?
  venueAddress    String?
  ceremonyVenue   String?
  ceremonyAddress String?
  city            String?
  state           String?
  style           String?
  storyText       String?   @db.Text
  estimatedGuests Int?
  estimatedBudget Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests      Guest[]
  gifts       Gift[]
  vendors     Vendor[]
  budgetItems BudgetItem[]
  plannerAssignments WeddingPlannerAssignment[]
  quotes      Quote[]

  @@index([userId])
}

model Guest {
  id                 String   @id @default(cuid())
  weddingId          String
  name               String
  email              String?
  phone              String?
  city               String?
  state              String?
  ddd                String?
  category           String?  // família_noivo, família_noiva, amigos_noivo, amigos_noiva, trabalho, lista_b
  rsvpStatus         String   @default("pendente") // pendente, confirmado, recusado
  plusOne             Boolean  @default(false)
  dietaryRestriction String?
  accommodation      Boolean  @default(false)
  needsTransport     Boolean  @default(false)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

model Gift {
  id          String   @id @default(cuid())
  weddingId   String
  name        String
  description String?
  price       Float?
  url         String?
  store       String?
  status      String   @default("available")
  reservedBy  String?
  reservedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

model Vendor {
  id        String   @id @default(cuid())
  weddingId String
  name      String
  category  String   // buffet, foto, som, decoração, convite, doces, bolo, DJ, carro, maquiagem, video, celebrante, outros
  phone     String?
  email     String?
  website   String?
  budget    Float?
  status    String   @default("cotado") // cotado, contratado, descartado
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  quotes  Quote[]

  @@index([weddingId])
}

model BudgetItem {
  id            String    @id @default(cuid())
  weddingId     String
  category      String
  description   String
  estimatedCost Float
  actualCost    Float?
  paidAmount    Float     @default(0)
  paidBy        String?
  dueDate       DateTime?
  status        String    @default("pendente") // pendente, pago, parcial
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

// ─── Planner Models ─────────────────────────────────────────

model WeddingPlanner {
  id             String   @id @default(cuid())
  userId         String   @unique
  slug           String?  @unique
  companyName    String
  cnpj           String?
  region         String   // ex: "SP/RJ/MG"
  specialties    String[] // ex: ["casamento clássico", "destination wedding"]
  commissionRate Float?   // percentual padrão
  bio            String?  @db.Text
  instagram      String?
  website        String?
  phone          String
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments   WeddingPlannerAssignment[]
  opportunities Opportunity[]
}

model WeddingPlannerAssignment {
  id               String   @id @default(cuid())
  plannerId        String
  weddingId        String
  role             String   // "principal", "assistente"
  status           String   @default("ativo") // ativo, concluído, cancelado
  commissionAmount Float?
  commissionPaid   Boolean  @default(false)
  assignedAt       DateTime @default(now())
  notes            String?

  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  wedding Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@unique([plannerId, weddingId])
  @@index([plannerId])
  @@index([weddingId])
}

model Quote {
  id           String    @id @default(cuid())
  vendorId     String
  weddingId    String
  totalValue   Float
  items        Json      // array de { description, quantity, unitPrice, total }
  status       String    @default("pendente") // pendente, aprovado, recusado
  paymentTerms String?
  installments Int?
  dueDate      DateTime?
  notes        String?
  rawOcrText   String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([weddingId])
}

model Opportunity {
  id                 String    @id @default(cuid())
  plannerId          String
  coupleName         String
  contactPhone       String?
  contactEmail       String?
  weddingDate        DateTime?
  venue              String?
  estimatedBudget    Float?
  source             String    // indicação, instagram, site, whatsapp, evento, outro
  stage              String    @default("lead") // lead, contato, proposta, negociação, fechado, perdido
  notes              String?   @db.Text
  lostReason         String?
  commissionEstimate Float?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)

  @@index([plannerId])
}
