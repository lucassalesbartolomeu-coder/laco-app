// Prisma schema do Laço — v2.0
// Adicionado: Payment, Withdrawal, Photo, AuditLog, RateLimit
// Atualizado: User (hashedPassword, image), Wedding (bank, totalRaised, cover, etc.)
// Atualizado: Gift (amount int, isGifted, giftedBy, payments), Guest (confirmed, message)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth Models ───────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String?  // legado — manter para compat
  hashedPassword String?  // novo campo bcrypt
  name           String?
  image          String?
  role            String   @default("COUPLE") // COUPLE, PLANNER, ADMIN
  onboardingStep  Int      @default(0)         // 0=não iniciado, -1=concluído
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Google Calendar integration
  googleAccessToken  String?  @db.Text
  googleRefreshToken String?  @db.Text
  googleCalendarId   String?

  // Referral
  referralCode String? @unique
  referredBy   String?

  accounts          Account[]
  sessions          Session[]
  weddings          Wedding[]
  withdrawals       Withdrawal[]
  weddingPlanner    WeddingPlanner?
  pushSubscriptions PushSubscription[]
  createdTasks      WeddingTask[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Wedding Models ────────────────────────────────────────

model Wedding {
  id              String    @id @default(cuid())
  userId          String
  slug            String?   @unique
  partnerName1    String
  partnerName2    String
  weddingDate     DateTime?
  venue           String?
  venueAddress    String?
  ceremonyVenue   String?
  ceremonyAddress String?
  city            String?
  state           String?
  style           String?
  storyText       String?   @db.Text
  estimatedGuests Int?
  estimatedBudget Float?
  coverImage      String?
  message         String?
  theme           Json?

  // Host info para pagamentos
  hostFullName    String?
  hostPhone       String?
  email           String?

  // Dados bancários (para saques)
  bankCode        String?
  bankAgency      String?
  bankAccount     String?
  bankAccountType String?
  bankCpf         String?   // encrypted AES-256-GCM

  // Financeiro
  totalRaised     Int       @default(0) // em centavos
  isPremium       Boolean   @default(false)

  // Parceiro (acesso compartilhado)
  partnerUserId      String?  // userId do parceiro vinculado
  partnerInviteToken String?  @unique // token para convite de parceiro

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests             Guest[]
  gifts              Gift[]
  vendors            Vendor[]
  budgetItems        BudgetItem[]
  budgetExpenses     BudgetExpense[]
  plannerAssignments WeddingPlannerAssignment[]
  quotes             Quote[]
  photos             Photo[]
  payments           Payment[]
  withdrawals        Withdrawal[]
  contracts          Contract[]
  identityKits       IdentityKit[]
  questionnaires     Questionnaire[]
  timelineEvents     TimelineEvent[]
  weddingEvents      WeddingEvent[]
  plannerInviteCodes PlannerInviteCode[]
  tasks              WeddingTask[]

  @@index([userId])
}

model WeddingEvent {
  id        String    @id @default(cuid())
  weddingId String
  wedding   Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name      String    // "Casamento Civil", "Jantar de Comemoração", "Festa Principal"
  date      DateTime?
  venue     String?
  notes     String?
  createdAt DateTime  @default(now())

  budgetItems BudgetItem[]

  @@index([weddingId])
}

model Guest {
  id                 String   @id @default(cuid())
  weddingId          String
  name               String
  email              String?
  phone              String?
  city               String?
  state              String?
  ddd                String?
  category           String?
  guestList          String    @default("A") // A = oficial (cerimonialista vê), B = reserva, C = talvez
  rsvpStatus         String    @default("pendente")
  confirmed          Boolean   @default(false)
  message            String?
  plusOne            Boolean   @default(false)
  plusOneName        String?
  dietaryRestriction String?
  dietaryNote        String?
  children           Int?
  tableGroup         String?
  isVip              Boolean   @default(false)
  accommodation      Boolean   @default(false)
  needsTransport     Boolean   @default(false)
  notes              String?
  whatsappSentAt     DateTime? // when the WhatsApp invite was last sent
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

model Gift {
  id          String    @id @default(cuid())
  weddingId   String
  name        String
  description String?
  amount      Int?      // valor em centavos
  price       Float?    // legado
  image       String?
  url         String?
  store       String?
  category    String?
  status      String    @default("available")
  sortOrder   Int       @default(0)
  reservedBy  String?
  reservedAt  DateTime?
  isGifted    Boolean   @default(false)
  giftedBy    String?
  giftedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  wedding  Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([weddingId])
}

enum VendorContractStatus {
  NONE
  PENDING
  SIGNED
}

model Vendor {
  id             String               @id @default(cuid())
  weddingId      String
  name           String
  category       String
  phone          String?
  email          String?
  website        String?
  budget         Float?
  status         String               @default("cotado")
  notes          String?
  contractStatus VendorContractStatus @default(NONE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  wedding   Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  quotes    Quote[]
  documents VendorDocument[]

  @@index([weddingId])
}

model VendorDocument {
  id        String   @id @default(cuid())
  vendorId  String
  name      String
  url       String
  size      Int?
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model BudgetItem {
  id            String    @id @default(cuid())
  weddingId     String
  eventId       String?   // null = custo geral do casamento
  category      String
  description   String
  estimatedCost Float
  actualCost    Float?
  paidAmount    Float     @default(0)
  paidBy        String?
  dueDate       DateTime?
  isPaid        Boolean   @default(false)
  status        String    @default("pendente")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wedding Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event   WeddingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([weddingId])
  @@index([eventId])
}

// ─── Payment Models ────────────────────────────────────────

model Payment {
  id            String    @id @default(cuid())
  weddingId     String
  giftId        String
  guestName     String
  guestEmail    String?
  guestPhone    String?
  guestCpf      String?   // encrypted AES-256-GCM
  message       String?
  amount        Int       // em centavos
  serviceFee    Int       @default(0)
  netAmount     Int
  paymentMethod String    @default("pix")
  status        String    @default("pending")
  externalId    String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  gift    Gift    @relation(fields: [giftId], references: [id], onDelete: Cascade)

  @@index([weddingId])
  @@index([giftId])
  @@index([externalId])
  @@index([status])
}

// Registro de gastos reais do orçamento (planejado vs. realizado)
model BudgetExpense {
  id          String   @id @default(cuid())
  weddingId   String
  description String
  amount      Float
  date        DateTime @default(now())
  method      String   @default("pix") // pix | cartao | transferencia | dinheiro
  status      String   @default("pago") // pago | pendente | parcela
  category    String?
  notes       String?
  createdAt   DateTime @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

model Withdrawal {
  id        String    @id @default(cuid())
  userId    String
  weddingId String
  amount    Int
  status    String    @default("pending")
  notes     String?
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([weddingId])
}

model Photo {
  id        String   @id @default(cuid())
  weddingId String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model RateLimit {
  key       String   @id
  count     Int      @default(1)
  expiresAt DateTime
  updatedAt DateTime @updatedAt
}

// ─── Planner Models ─────────────────────────────────────────

model WeddingPlanner {
  id             String   @id @default(cuid())
  userId         String   @unique
  slug           String?  @unique
  companyName    String
  cnpj           String?
  region         String
  specialties    String[]
  commissionRate Float?
  bio            String?  @db.Text
  instagram      String?
  website        String?
  phone          String
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments    WeddingPlannerAssignment[]
  opportunities  Opportunity[]
  contracts      Contract[]
  teamMembers    PlannerTeamMember[]
  questionnaires Questionnaire[]
  tasks          PlannerTask[]
  notifications  PlannerNotification[]
  communityPosts    CommunityPost[]
  communityLikes    CommunityLike[]
  communityComments CommunityComment[]
  taskTemplates     TaskTemplate[]
}

model PlannerInviteCode {
  id        String    @id @default(cuid())
  weddingId String
  code      String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  usedBy    String?
  createdAt DateTime  @default(now())

  wedding   Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
  @@index([code])
}

model WeddingPlannerAssignment {
  id                   String   @id @default(cuid())
  plannerId            String
  weddingId            String
  role                 String
  status               String   @default("ativo")
  commissionAmount     Float?
  commissionPaid       Boolean  @default(false)
  assignedAt           DateTime @default(now())
  notes                String?
  assignedTeamMemberId String?

  planner    WeddingPlanner     @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  wedding    Wedding            @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  teamMember PlannerTeamMember? @relation(fields: [assignedTeamMemberId], references: [id], onDelete: SetNull)

  @@unique([plannerId, weddingId])
  @@index([plannerId])
  @@index([weddingId])
}

model Quote {
  id           String    @id @default(cuid())
  vendorId     String
  weddingId    String
  totalValue   Float
  items        Json
  status       String    @default("pendente")
  paymentTerms String?
  installments Int?
  dueDate      DateTime?
  notes        String?
  rawOcrText   String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([weddingId])
}

model Opportunity {
  id                 String    @id @default(cuid())
  plannerId          String
  coupleName         String
  contactPhone       String?
  contactEmail       String?
  weddingDate        DateTime?
  venue              String?
  estimatedBudget    Float?
  source             String
  stage              String    @default("lead")
  notes              String?   @db.Text
  lostReason         String?
  commissionEstimate Float?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)

  @@index([plannerId])
}

// ─── Sprint 9 — Contratos + Equipe ─────────────────────────

model Contract {
  id              String    @id @default(cuid())
  plannerId       String
  weddingId       String
  terms           String    @db.Text
  value           Float?
  signedByPlanner Boolean   @default(false)
  signedByCouple  Boolean   @default(false)
  plannerSignedAt DateTime?
  coupleSignedAt  DateTime?
  plannerName     String?
  coupleName      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  wedding Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([plannerId])
  @@index([weddingId])
}

// ─── Sprint 7 — Identity Kit ────────────────────────────────

model IdentityKit {
  id            String   @id @default(cuid())
  weddingId     String
  style         String   // clássico | rústico | moderno | romântico | minimalista | boho
  paletteChoice String   // "ai" | "marfim-dourado" | "verde-cobre" | etc.
  mood          String   // formal | descontraído | íntimo | grande festa | luxo | DIY
  tone          String   // poético | divertido | tradicional | contemporâneo
  referenceUrls String[]
  aiResponse      Json?     // full AI-generated identity (palette, typography, invite, menu, decoration, siteTheme)
  generatedImages String[]  // DALL-E generated image URLs (4 invites + 1 logo)
  appliedAt       DateTime? // when the couple clicked "Aplicar ao meu site"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

model PlannerTeamMember {
  id        String   @id @default(cuid())
  plannerId String
  name      String
  email     String?
  role      String   @default("assistente")
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planner     WeddingPlanner             @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  assignments WeddingPlannerAssignment[]

  @@index([plannerId])
}

// ─── Questionários (Cerimonialista → Casal) ─────────────────

model Questionnaire {
  id          String    @id @default(cuid())
  plannerId   String
  weddingId   String
  title       String    @default("Questionário de Preferências")
  token       String    @unique @default(cuid())
  questions   Json
  answers     Json?
  answeredAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  wedding Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([plannerId])
  @@index([weddingId])
}

// ─── Notificações da Cerimonialista ──────────────────────────

model PlannerNotification {
  id        String   @id @default(cuid())
  plannerId String
  weddingId String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)

  @@index([plannerId])
}

// ─── Tarefas da Cerimonialista ───────────────────────────────

model PlannerTask {
  id        String    @id @default(cuid())
  plannerId String
  weddingId String?
  title     String
  dueDate   DateTime?
  done      Boolean   @default(false)
  priority  String    @default("normal")
  createdAt DateTime  @default(now())

  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)

  @@index([plannerId])
}

// ─── Timeline de Eventos do Casamento ───────────────────────

model TimelineEvent {
  id          String  @id @default(cuid())
  weddingId   String
  time        String
  title       String
  description String? @db.Text
  responsible String?
  category    String  @default("cerimonia")
  status      String  @default("pendente")
  order       Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}


// ─── Comunidade de Cerimonialistas ───────────────────────────

model CommunityPost {
  id        String   @id @default(cuid())
  plannerId String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planner  WeddingPlanner     @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  likes    CommunityLike[]
  comments CommunityComment[]

  @@index([plannerId])
  @@index([createdAt])
}

model CommunityLike {
  id        String   @id @default(cuid())
  postId    String
  plannerId String
  createdAt DateTime @default(now())

  post    CommunityPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)

  @@unique([postId, plannerId])
  @@index([postId])
}

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  plannerId String
  content   String
  createdAt DateTime @default(now())

  post    CommunityPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ─── Push Notifications ──────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  weddingId String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([weddingId])
}

// ─── Sprint Tasks — Tarefas Compartilhadas ──────────────────

enum TaskPhase {
  TWELVE_MONTHS
  SIX_MONTHS
  THREE_MONTHS
  ONE_MONTH
  ONE_WEEK
  DAY_OF
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model TaskTemplate {
  id          String             @id @default(cuid())
  plannerId   String
  name        String
  description String?
  phase       TaskPhase
  items       TaskTemplateItem[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)

  @@index([plannerId])
}

model TaskTemplateItem {
  id                String       @id @default(cuid())
  templateId        String
  title             String
  description       String?
  priority          TaskPriority
  daysBeforeWedding Int

  template TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model WeddingTask {
  id             String       @id @default(cuid())
  weddingId      String
  createdById    String
  title          String
  description    String?
  priority       TaskPriority
  dueDate        DateTime?
  status         TaskStatus   @default(PENDING)
  templateItemId String?
  notifiedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  wedding     Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  createdBy   User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([weddingId])
  @@index([dueDate])
  @@index([dueDate, notifiedAt])
}
