// Prisma schema do Laço — v2.0
// Adicionado: Payment, Withdrawal, Photo, AuditLog, RateLimit
// Atualizado: User (hashedPassword, image), Wedding (bank, totalRaised, cover, etc.)
// Atualizado: Gift (amount int, isGifted, giftedBy, payments), Guest (confirmed, message)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth Models ───────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String?  // legado — manter para compat
  hashedPassword String?  // novo campo bcrypt
  name           String?
  image          String?
  role            String   @default("COUPLE") // COUPLE, PLANNER, ADMIN
  onboardingStep  Int      @default(0)         // 0=não iniciado, -1=concluído
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Google Calendar integration
  googleAccessToken  String?  @db.Text
  googleRefreshToken String?  @db.Text
  googleCalendarId   String?

  // Referral
  referralCode String? @unique
  referredBy   String?

  accounts       Account[]
  sessions       Session[]
  weddings       Wedding[]
  withdrawals    Withdrawal[]
  weddingPlanner WeddingPlanner?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Wedding Models ────────────────────────────────────────

model Wedding {
  id              String    @id @default(cuid())
  userId          String
  slug            String?   @unique
  partnerName1    String
  partnerName2    String
  weddingDate     DateTime?
  venue           String?
  venueAddress    String?
  ceremonyVenue   String?
  ceremonyAddress String?
  city            String?
  state           String?
  style           String?
  storyText       String?   @db.Text
  estimatedGuests Int?
  estimatedBudget Float?
  coverImage      String?
  message         String?
  theme           Json?

  // Host info para pagamentos
  hostFullName    String?
  hostPhone       String?
  email           String?

  // Dados bancários (para saques)
  bankCode        String?
  bankAgency      String?
  bankAccount     String?
  bankAccountType String?
  bankCpf         String?   // encrypted AES-256-GCM

  // Financeiro
  totalRaised     Int       @default(0) // em centavos
  isPremium       Boolean   @default(false)

  // Parceiro (acesso compartilhado)
  partnerUserId      String?  // userId do parceiro vinculado
  partnerInviteToken String?  @unique // token para convite de parceiro

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests             Guest[]
  gifts              Gift[]
  vendors            Vendor[]
  budgetItems        BudgetItem[]
  plannerAssignments WeddingPlannerAssignment[]
  quotes             Quote[]
  photos             Photo[]
  payments           Payment[]
  withdrawals        Withdrawal[]
  contracts          Contract[]
  identityKits       IdentityKit[]

  @@index([userId])
}

model Guest {
  id                 String   @id @default(cuid())
  weddingId          String
  name               String
  email              String?
  phone              String?
  city               String?
  state              String?
  ddd                String?
  category           String?
  rsvpStatus         String    @default("pendente")
  confirmed          Boolean   @default(false)
  message            String?
  plusOne            Boolean   @default(false)
  dietaryRestriction String?
  accommodation      Boolean   @default(false)
  needsTransport     Boolean   @default(false)
  notes              String?
  whatsappSentAt     DateTime? // when the WhatsApp invite was last sent
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

model Gift {
  id          String    @id @default(cuid())
  weddingId   String
  name        String
  description String?
  amount      Int?      // valor em centavos
  price       Float?    // legado
  image       String?
  url         String?
  store       String?
  category    String?
  status      String    @default("available")
  sortOrder   Int       @default(0)
  reservedBy  String?
  reservedAt  DateTime?
  isGifted    Boolean   @default(false)
  giftedBy    String?
  giftedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  wedding  Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([weddingId])
}

model Vendor {
  id        String   @id @default(cuid())
  weddingId String
  name      String
  category  String
  phone     String?
  email     String?
  website   String?
  budget    Float?
  status    String   @default("cotado")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  quotes  Quote[]

  @@index([weddingId])
}

model BudgetItem {
  id            String    @id @default(cuid())
  weddingId     String
  category      String
  description   String
  estimatedCost Float
  actualCost    Float?
  paidAmount    Float     @default(0)
  paidBy        String?
  dueDate       DateTime?
  isPaid        Boolean   @default(false)
  status        String    @default("pendente")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

// ─── Payment Models ────────────────────────────────────────

model Payment {
  id            String    @id @default(cuid())
  weddingId     String
  giftId        String
  guestName     String
  guestEmail    String?
  guestPhone    String?
  guestCpf      String?   // encrypted AES-256-GCM
  message       String?
  amount        Int       // em centavos
  serviceFee    Int       @default(0)
  netAmount     Int
  paymentMethod String    @default("pix")
  status        String    @default("pending")
  externalId    String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  gift    Gift    @relation(fields: [giftId], references: [id], onDelete: Cascade)

  @@index([weddingId])
  @@index([giftId])
  @@index([externalId])
  @@index([status])
}

model Withdrawal {
  id        String    @id @default(cuid())
  userId    String
  weddingId String
  amount    Int
  status    String    @default("pending")
  notes     String?
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([weddingId])
}

model Photo {
  id        String   @id @default(cuid())
  weddingId String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model RateLimit {
  key       String   @id
  count     Int      @default(1)
  expiresAt DateTime
  updatedAt DateTime @updatedAt
}

// ─── Planner Models ─────────────────────────────────────────

model WeddingPlanner {
  id             String   @id @default(cuid())
  userId         String   @unique
  slug           String?  @unique
  companyName    String
  cnpj           String?
  region         String
  specialties    String[]
  commissionRate Float?
  bio            String?  @db.Text
  instagram      String?
  website        String?
  phone          String
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments   WeddingPlannerAssignment[]
  opportunities Opportunity[]
  contracts     Contract[]
  teamMembers   PlannerTeamMember[]
}

model WeddingPlannerAssignment {
  id                   String   @id @default(cuid())
  plannerId            String
  weddingId            String
  role                 String
  status               String   @default("ativo")
  commissionAmount     Float?
  commissionPaid       Boolean  @default(false)
  assignedAt           DateTime @default(now())
  notes                String?
  assignedTeamMemberId String?

  planner    WeddingPlanner     @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  wedding    Wedding            @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  teamMember PlannerTeamMember? @relation(fields: [assignedTeamMemberId], references: [id], onDelete: SetNull)

  @@unique([plannerId, weddingId])
  @@index([plannerId])
  @@index([weddingId])
}

model Quote {
  id           String    @id @default(cuid())
  vendorId     String
  weddingId    String
  totalValue   Float
  items        Json
  status       String    @default("pendente")
  paymentTerms String?
  installments Int?
  dueDate      DateTime?
  notes        String?
  rawOcrText   String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([weddingId])
}

model Opportunity {
  id                 String    @id @default(cuid())
  plannerId          String
  coupleName         String
  contactPhone       String?
  contactEmail       String?
  weddingDate        DateTime?
  venue              String?
  estimatedBudget    Float?
  source             String
  stage              String    @default("lead")
  notes              String?   @db.Text
  lostReason         String?
  commissionEstimate Float?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)

  @@index([plannerId])
}

// ─── Sprint 9 — Contratos + Equipe ─────────────────────────

model Contract {
  id              String    @id @default(cuid())
  plannerId       String
  weddingId       String
  terms           String    @db.Text
  value           Float?
  signedByPlanner Boolean   @default(false)
  signedByCouple  Boolean   @default(false)
  plannerSignedAt DateTime?
  coupleSignedAt  DateTime?
  plannerName     String?
  coupleName      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  planner WeddingPlanner @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  wedding Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([plannerId])
  @@index([weddingId])
}

// ─── Sprint 7 — Identity Kit ────────────────────────────────

model IdentityKit {
  id            String   @id @default(cuid())
  weddingId     String
  style         String   // clássico | rústico | moderno | romântico | minimalista | boho
  paletteChoice String   // "ai" | "marfim-dourado" | "verde-cobre" | etc.
  mood          String   // formal | descontraído | íntimo | grande festa | luxo | DIY
  tone          String   // poético | divertido | tradicional | contemporâneo
  referenceUrls String[]
  aiResponse      Json?     // full AI-generated identity (palette, typography, invite, menu, decoration, siteTheme)
  generatedImages String[]  // DALL-E generated image URLs (4 invites + 1 logo)
  appliedAt       DateTime? // when the couple clicked "Aplicar ao meu site"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

model PlannerTeamMember {
  id        String   @id @default(cuid())
  plannerId String
  name      String
  email     String?
  role      String   @default("assistente")
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planner     WeddingPlanner             @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  assignments WeddingPlannerAssignment[]

  @@index([plannerId])
}
